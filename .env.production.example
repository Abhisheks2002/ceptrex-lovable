# =====================================================================
# CEPTREX — Production environment template
# Set these in your host's secret manager (Cloudflare, Vercel, etc.).
# DO NOT commit real values. Mark SECRET vars as encrypted in your host.
# =====================================================================

# -------- Application --------
NODE_ENV=production
VITE_APP_NAME=Ceptrex
VITE_SITE_URL=https://ceptrex.com           # canonical production URL

# -------- Supabase (required if Lovable Cloud is enabled) --------
VITE_SUPABASE_URL=https://<ref>.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=<anon-key>     # PUBLIC — safe in client
SUPABASE_URL=https://<ref>.supabase.co
SUPABASE_PUBLISHABLE_KEY=<anon-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role>     # SECRET — never expose

# -------- AI --------
LOVABLE_API_KEY=<lovable-ai-gateway-key>     # SECRET
# OPENAI_API_KEY=...                          # SECRET (optional)
# ANTHROPIC_API_KEY=...                       # SECRET (optional)

# -------- Email --------
RESEND_API_KEY=<resend-prod-key>             # SECRET

# -------- Analytics --------
VITE_GA_MEASUREMENT_ID=G-XXXXXXX
# VITE_POSTHOG_KEY=phc_...
# VITE_CLARITY_PROJECT_ID=...

# -------- Monitoring --------
SENTRY_DSN=https://<key>@o<org>.ingest.sentry.io/<project>   # SECRET
